# Copie este arquivo para .env e substitua pelos seus valores reais.

GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL_ID=gemini-3-flash-preview

# Caminho local para a chave de Service Account (NUNCA commitar).
GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/service-account.json

HOST=0.0.0.0
PORT=8000
PUBLIC_API_URL=http://localhost:3000

# Opcional: token compartilhado para integrações webhook internas.
API_COMMUNICATION_TOKEN=
